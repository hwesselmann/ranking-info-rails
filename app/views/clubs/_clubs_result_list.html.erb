<div class="overflow-x-auto">
  <table class="w-full">
    <thead>
      <tr class="bg-gray-800 text-white font-bold">
        <th class="text-left py-2 px-2">Vereinsname</th>
        <th class="text-center py-2 px-2">Jugend</th>
        <th class="text-center py-2 px-2">Herren/Damen</th>
      </tr>
    </thead>
    <tbody>
      <% @clubs.each do |club| %>
        <tr class="border-b border-gray-200 even:bg-gray-50">
          <td class="py-1 px-2"><%= link_to club[:name], club_path(club[:name]), class: 'text-brand', data: { turbo_frame: '_top' } %></td>
          <td class="text-center py-1 px-2"><%= club[:youth_count] %></td>
          <td class="text-center py-1 px-2"><%= club[:adult_count] %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
