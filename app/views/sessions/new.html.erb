<% provide(:title, "Log in") %>
<div class="w-full max-w-md mx-auto mt-8">
  <h1 class="text-2xl font-bold text-left mb-3 mt-3">
    Login
  </h1>
  <%= form_with(url: login_path, scope: :session, local: true) do |f| %>
    <div class="mb-4">
      <%= f.label :email, class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.email_field :email, class: 'w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand' %>
    </div>
    <div class="mb-4">
      <%= f.label :password, class: 'block text-sm font-medium text-gray-700 mb-1' %>
      <%= f.password_field :password, class: 'w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand' %>
    </div>
    <%= f.submit "Log in", class: "bg-brand text-white px-4 py-2 rounded hover:opacity-90 cursor-pointer mt-2" %>
  <% end %>
</div>
