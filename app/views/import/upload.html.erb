<% provide(:title, "Upload und Import") %>
<h1 class="text-2xl font-bold text-left mb-3 mt-3">
  Upload und Import
</h1>
<p class="mb-3">
  Hier können neue Daten in das System geladen werden.
  Der Import dauert je nach Dateigröße und Systemleistung zwischen 2 und 15 Minuten.
  Nach Abschluss erhälst Du eine Erfolgsmeldung - hab ein wenig Geduld!
</p>
<p class="mb-3">
  Informationen zum Layout der Importdatei findest Du im README, ein Beispiel liegt unter
  <i>test/fixtures/files</i>.
</p>
<%= form_with(url: {action: :import}, multipart: true) do %>
  <div class="flex items-center gap-3 mt-3 mb-3">
    <div id="file-upload" class="flex items-center">
      <label class="flex items-center gap-2 bg-gray-100 border border-gray-300 rounded px-4 py-2 cursor-pointer hover:bg-gray-200">
        <i class="fas fa-upload"></i>
        <span>Datei auswählen…</span>
        <%= file_field_tag 'file', class: 'hidden' %>
      </label>
      <span id="file-name" class="ml-3 text-sm text-gray-600">Datei</span>
    </div>
    <%= submit_tag 'upload & import', class: 'bg-brand text-white px-4 py-2 rounded hover:opacity-90 cursor-pointer' %>
  </div>
<% end %>

<script>
  const fileInput = document.querySelector('#file-upload input[type=file]');
  fileInput.onchange = () => {
    if (fileInput.files.length > 0) {
      const fileName = document.querySelector('#file-name');
      fileName.textContent = fileInput.files[0].name;
    }
  }
</script>
