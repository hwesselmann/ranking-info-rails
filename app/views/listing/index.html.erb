<% provide(:title, 'Ranglisten') %>
<% provide(:meta_content, "Durchsuchbare und filterbare Version der Deutschen Tennis-Rangliste.") %>
<h1 class="text-2xl font-bold text-left mb-3 mt-3">
  Ranglisten
</h1>
<%= form_tag(listings_path, method: 'get', class: 'mb-4') do %>
<div class="flex flex-wrap items-end gap-3">
  <div>
    <%= label_tag 'quarter', 'Stichtag', class: 'block text-sm font-medium text-gray-700' %>
    <%= select_tag(:quarter, grouped_options_for_select(@quarters, params[:quarter] || @quarters.first), class: 'border border-gray-300 rounded px-2 py-1 text-sm') %>
    <br>
    <label for="year_end" class="text-sm">
      <%= check_box_tag 'year_end', 1, params[:year_end].eql?('1') %> Abschlussrangliste
    </label>
  </div>
  <div>
    <%= label_tag 'gender', 'Geschlecht', class: 'block text-sm font-medium text-gray-700' %>
    <%= select_tag(:gender, options_for_select(['Herren', 'Damen', 'Junioren', 'Juniorinnen'], params[:gender] || 'Herren'), class: 'border border-gray-300 rounded px-2 py-1 text-sm') %>
  </div>
  <div>
    <%= label_tag 'age-group', 'Altersklasse', class: 'block text-sm font-medium text-gray-700' %>
    <%= select_tag(:age_group, options_for_select(['U11', 'U12', 'U13', 'U14', 'U15', 'U16', 'U17', 'U18'], params[:age_group] || ''), include_blank: true, class: 'border border-gray-300 rounded px-2 py-1 text-sm') %>
  </div>
  <div>
    <%= label_tag 'age_group_options', 'Extras', class: 'block text-sm font-medium text-gray-700' %>
    <%= select_tag(:age_group_options, options_for_select([['nur Geburtsjahrgang', 'only_yob'], ['auch Jüngere einbeziehen', 'include_younger']], params[:age_group_options] || ''), include_blank: true, class: 'border border-gray-300 rounded px-2 py-1 text-sm') %>
  </div>
  <div>
    <%= label_tag 'federation', 'Verband', class: 'block text-sm font-medium text-gray-700' %>
    <%= select_tag(:federation, options_for_select(@federations, params[:federation] || ''), include_blank: true, class: 'border border-gray-300 rounded px-2 py-1 text-sm') %>
  </div>
  <div>
    <%= label_tag 'club', 'Verein', class: 'block text-sm font-medium text-gray-700' %>
    <%= search_field_tag 'club', params[:club], class: 'border border-gray-300 rounded px-2 py-1 text-sm', size: '10', placeholder: 'Verein' %>
  </div>
  <div>
    <%= submit_tag 'Liste abrufen', class: 'bg-brand text-white px-3 py-1 text-sm rounded hover:opacity-90 cursor-pointer' %>
  </div>
</div>
<% end %>
<% if @rankings.present? %>
  <%= render 'ranking_list' %>
<% else %>
  <% if params[:commit] %>
    <div>Es wurden leider keine Daten für diese Suchkriterien gefunden.</div>
  <% else %>
    <%= render 'list_intro' %>
  <% end %>
<% end %>
