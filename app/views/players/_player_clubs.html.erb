<span class="text-sm font-semibold">Bisherige Vereine</span>
<div class="mt-3">
  <div class="bg-gray-800 text-white font-bold py-2 px-2">Verein</div>
  <% @player.clubs.each do |curr_club| %>
    <div class="border-b border-gray-200 py-1 px-2">
      <%= curr_club.name %> / <%= curr_club.federation %>
    </div>
  <% end %>
</div>
