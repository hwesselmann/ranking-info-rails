<% adult_age_group = @complete_rankings.find { |r| r.key?('m00') }&.then { 'm00' } || 'w00' %>
<span class="title is-6">Gesamtverlauf Aktive</span>
<div class="mt-3">
  <div class="columns is-mobile has-text-white has-background-dark has-text-weight-bold">
    <div class="column is-2"><i class="far fa-calendar-alt"></i></div>
    <div class="column is-2"><i class="fas fa-poll"></i></div>
    <div class="column is-1"><%= adult_age_group %></div>
  </div>
  <% @complete_rankings.each_with_index do |ran, index| %>
    <% next unless ran.key?(adult_age_group) %>
    <div class="columns is-mobile <%= 'striped' unless index.even? %>">
      <div class="column is-2"><%= ran['year'] %>/<%= ran['quarter'] %></div>
      <div class="column is-2"><%= ran['score'] %></div>
      <div class="column is-1"><%= ran[adult_age_group] %></div>
    </div>
  <% end %>
</div>
