<% provide(:title, 'Spielersuche') %>
<% provide(:meta_content, "Suchen von Spielern, die im verfügbaren Datenbestand eine Platzierung auf der Deutschen Tennis-Jugendrangliste hatten.") %>
<h1 class="text-2xl font-bold text-left mb-3 mt-3">
  Spielersuche
</h1>
<%= form_tag(players_path, method: 'get', class: 'mb-3', data: { turbo_frame: 'player-results' }) do %>
  <div class="flex flex-wrap items-center gap-2">
    <%= search_field_tag 'dtb_id', params[:dtb_id], class: 'border border-gray-300 rounded px-2 py-1 text-sm', placeholder: 'DTB-ID' %>
    <%= search_field_tag 'lastname', params[:lastname], class: 'border border-gray-300 rounded px-2 py-1 text-sm', placeholder: 'Nachname' %>
    <%= search_field_tag 'yob', params[:yob], class: 'border border-gray-300 rounded px-2 py-1 text-sm', placeholder: 'Geburtsjahr' %>
    <%= submit_tag 'suchen', class: 'bg-brand text-white px-3 py-1 text-sm rounded hover:opacity-90 cursor-pointer' %>
  </div>
<% end %>
<turbo-frame id="player-results" data-turbo-action="advance">
  <% if @players.present? %>
    <%= render 'player_result_list' %>
  <% elsif params[:commit] %>
    <div>Es wurden keine Spieler für diese Suchkriterien gefunden.</div>
  <% else %>
    <%= render 'search_intro' %>
  <% end %>
</turbo-frame>
