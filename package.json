{
  "name": "ranking_info",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "esbuild app/javascript/application.js --bundle --sourcemap --outdir=app/assets/builds --public-path=/assets",
    "build:css": "sass ./app/javascript/stylesheets/application.scss ./app/assets/builds/fontawesome.css --no-source-map --load-path=node_modules && tailwindcss -i ./app/javascript/stylesheets/application.css -o ./app/assets/builds/application.css --minify",
    "postinstall": "cp -r node_modules/@fortawesome/fontawesome-free/webfonts app/assets/ && cp -r node_modules/@fortawesome/fontawesome-free/webfonts public/"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@rails/actioncable": "^6.1.5",
    "@rails/activestorage": "^6.1.5",
    "@rails/ujs": "^6.1.5",
    "chartkick": "^4.0.5",
    "highcharts": "^10.0.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "esbuild": "^0.25.0",
    "sass": "^1.77.0"
  }
}
