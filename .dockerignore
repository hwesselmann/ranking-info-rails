# Version control
.git
.github
.gitignore

# Environment and secrets
.env*

# Dependencies (installed during build)
node_modules
app/assets/builds/
app/assets/webfonts/

# Compiled output (built fresh during docker build)
public/assets/*

# Test and development tooling
test/
coverage/
Guardfile
.rspec
.rubocop.yml
.byebug_history
.eslintignore
.eslintrc.js
.yarnclean
yarn-error.log

# Editor and IDE
.editorconfig
.idea
.vscode
.ruby-lsp/
.claude

# Runtime directories (created by the app)
storage/
log/*
tmp/*
!tmp/pids/
!tmp/pids/.keep

# Local databases
db/*.sqlite3

# Docker files themselves
Dockerfile
docker-compose.*

# Docs and local config
README.md
LICENSE
.foreman
.nvmrc
Procfile*
